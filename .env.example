# PlanetFlow - environment variables
# Copy this file to .env and fill in the values.

# Database
# Linux native: set DATABASE_URL directly
# Docker Compose: DB_PASSWORD is usually enough because DATABASE_URL is assembled in the container
DATABASE_URL=postgresql://planetflow:PASSWORD@localhost/planetflow

# Docker / Compose PostgreSQL password
DB_PASSWORD=change_me

# EVE Online SSO
# Register your application at https://developers.eveonline.com
EVE_CLIENT_ID=your_client_id
EVE_CLIENT_SECRET=your_client_secret
EVE_CALLBACK_URL=http://your-domain-or-ip/auth/callback

# ESI scopes — register ALL of these in your EVE developer app.
# Use spaces between scopes, not commas.
EVE_SCOPES=esi-planets.manage_planets.v1 esi-planets.read_customs_offices.v1 esi-location.read_location.v1 esi-characters.read_corporation_roles.v1 esi-skills.read_skills.v1 esi-fittings.read_fittings.v1

# Security key for session signing
# Use a random value with at least 32 characters.
SECRET_KEY=replace_me_with_a_long_random_secret_key

# Server
APP_PORT=8000
DEBUG=false
# Set to true ONLY when serving over HTTPS.
# With HTTP this must be false — otherwise the browser drops the session
# cookie and every login redirects back to the login page.
COOKIE_SECURE=false

# Optional integrations
JANICE_API_KEY=

# RabbitMQ (used by Celery for background job queue)
# Leave empty to run without Celery (APScheduler fallback, single-process dev mode)
RABBITMQ_USER=planetflow
RABBITMQ_PASS=change_me_rabbit
CELERY_BROKER_URL=amqp://planetflow:change_me_rabbit@rabbitmq:5672//

# Web worker count (gunicorn).
# Rule of thumb: 2 workers per CPU core, but keep RAM in mind.
# Each worker loads the full app (~400-500 MB). Start with 2, increase if needed.
WEB_WORKERS=2

# Optional: Sentry error tracking
# Leave empty to disable. Get a DSN at https://sentry.io
SENTRY_DSN=

# Optional: Flower (Celery task monitor) credentials
# Used when starting with: docker compose --profile monitoring up
FLOWER_USER=admin
FLOWER_PASS=change_me_flower

# Optional: nginx profile port (default 80)
# Used when starting with: docker compose --profile nginx up
NGINX_PORT=80
