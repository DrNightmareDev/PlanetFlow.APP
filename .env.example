# EVE PI Manager - Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus

# Datenbank
# LXC: DATABASE_URL=postgresql://evepi:PASSWORT@localhost/evepi
# Docker Compose: DATABASE_URL wird automatisch gesetzt, nur DB_PASSWORD nötig
DATABASE_URL=postgresql://evepi:PASSWORT@localhost/evepi

# Docker: Passwort für den PostgreSQL-Container (statt DATABASE_URL)
DB_PASSWORD=sicheres_passwort

# EVE Online SSO - Registriere deine App unter https://developers.eveonline.com
EVE_CLIENT_ID=dein_client_id
EVE_CLIENT_SECRET=dein_client_secret
EVE_CALLBACK_URL=http://deine-domain.com/auth/callback

# ESI Scopes (kommagetrennt)
EVE_SCOPES=esi-planets.manage_planets.v1,esi-planets.read_customs_offices.v1,esi-location.read_location.v1,esi-search.search_structures.v1,esi-characters.read_corporation_roles.v1,esi-skills.read_skills.v1

# Sicherheitsschlüssel (zufällig, mindestens 32 Zeichen)
SECRET_KEY=aendere_mich_zu_einem_sicheren_zufaelligen_schluessel

# Server
# LXC: Port der Uvicorn-Instanz
# Docker: Port auf dem Nginx nach außen lauscht (Standard: 80)
APP_PORT=8000
DEBUG=false
