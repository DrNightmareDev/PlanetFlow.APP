# PlanetFlow - Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in ALL required values.
#
#   cp .env.example .env
#   nano .env
#
# REQUIRED fields are marked with [REQUIRED].
# Optional fields can be left empty to disable the feature.
# -------------------------------------------------------

# -- Database --------------------------------------------
# Docker Compose assembles DATABASE_URL automatically from DB_PASSWORD.
# Only set DATABASE_URL explicitly if you connect to an external database.
# [REQUIRED]
DB_PASSWORD=change_me                                             
#DATABASE_URL=postgresql://planetflow:PASSWORD@db/planetflow

# -- Owner -----------------------------------------------
# The EVE character ID whose account is permanently the Owner.
# Owner = always admin, can grant/revoke admin rights for others.
# To transfer ownership: change this value and restart the app.
# Find your character ID at: https://evewho.com  or  zkillboard.com
# [REQUIRED]
EVE_OWNER_CHARACTER_ID=123456789                                  

# -- EVE Online SSO --------------------------------------
# Register your application at https://developers.eveonline.com
# Callback URL must exactly match what you register there.
# [REQUIRED]
EVE_CLIENT_ID=your_client_id                                      
EVE_CLIENT_SECRET=your_client_secret                              
EVE_CALLBACK_URL=http://localhost:8080/auth/callback              

# ESI scopes - register ALL of these in your EVE developer app.
EVE_SCOPES=esi-planets.manage_planets.v1 esi-planets.read_customs_offices.v1 esi-location.read_location.v1 esi-characters.read_corporation_roles.v1 esi-skills.read_skills.v1 esi-fittings.read_fittings.v1

# -- Session Security ------------------------------------
# Generate a strong secret (lower/upper/digit/special):
#   python3 -c "import secrets,string; l=string.ascii_lowercase; u=string.ascii_uppercase; d=string.digits; s='!@#$%^&*()-_=+[]{}:,.?'; a=l+u+d+s; p=[secrets.choice(l),secrets.choice(u),secrets.choice(d),secrets.choice(s)]+[secrets.choice(a) for _ in range(44)]; secrets.SystemRandom().shuffle(p); print(''.join(p))"
#   python  -c "import secrets,string; l=string.ascii_lowercase; u=string.ascii_uppercase; d=string.digits; s='!@#$%^&*()-_=+[]{}:,.?'; a=l+u+d+s; p=[secrets.choice(l),secrets.choice(u),secrets.choice(d),secrets.choice(s)]+[secrets.choice(a) for _ in range(44)]; secrets.SystemRandom().shuffle(p); print(''.join(p))"
# [REQUIRED]
SECRET_KEY=replace_me_with_a_long_random_secret_key               

# Set to true when serving over HTTPS (required for production).
# With HTTP this must be false - browser drops the session cookie otherwise.
COOKIE_SECURE=false
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=30

# -- RabbitMQ (Celery broker) ----------------------------
RABBITMQ_USER=planetflow
# [REQUIRED]
RABBITMQ_PASS=change_me_rabbit                                    

# -- Web Workers -----------------------------------------
# Rule of thumb: 2 per CPU core, but each worker uses ~400-500 MB RAM.
# Hetzner CX22 (2 vCPU, 4 GB): WEB_WORKERS=2
# Hetzner CX32 (4 vCPU, 8 GB): WEB_WORKERS=4
WEB_WORKERS=2

# -- Application -----------------------------------------
DEBUG=false

# -- Optional: Sentry error tracking --------------------
# Leave empty to disable.
SENTRY_DSN=

# -- Optional: Janice appraisal API ---------------------
JANICE_API_KEY=

# -- Optional: Flower (Celery task monitor) -------------
# Accessible via: docker compose --profile monitoring up
FLOWER_USER=admin
FLOWER_PASS=replace_me_with_a_unique_random_password

# -- nginx TLS mode --------------------------------------
# https  (default) - nginx handles TLS via Let's Encrypt.
#                    certbot renews automatically. Set EVE_CALLBACK_URL to
#                    https://yourdomain.com/auth/callback.
#
# proxy            - an upstream device (OPNsense, Traefik, Caddy, etc.) terminates
#                    TLS. nginx listens on port 80 only and trusts the
#                    X-Forwarded-Proto header from the upstream.
#                    Keep COOKIE_SECURE=true - your upstream sends HTTPS to users.
#
# local            - no nginx TLS and no cert wait. Use for local development.
NGINX_MODE=local

# Host ports mapped to nginx container ports.
# Local recommendation: HTTP 8080, HTTPS 8443 (HTTPS port is unused in local/proxy mode).
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
